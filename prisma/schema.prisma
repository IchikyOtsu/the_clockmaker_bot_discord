// =============================================================
// The Clockmaster Bot — Prisma Schema (documentation only)
// Ce fichier documente la structure de la base de données Supabase.
// Il n'est PAS utilisé par le bot Python — voir sql/schema.sql
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Un compte Discord sur un serveur spécifique.
model Player {
  discord_id String     @db.Text
  guild_id   String     @db.Text
  created_at DateTime   @default(now()) @db.Timestamptz(6)

  character  Character?

  @@id([discord_id, guild_id])
  @@map("players")
}

/// Personnage unique par joueur par serveur.
/// avatar_url : photo uploadée dans Supabase Storage (bucket "avatars").
/// date_naissance : format ISO YYYY-MM-DD, affiché en DD/MM/YYYY.
model Character {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discord_id     String    @db.Text
  guild_id       String    @db.Text
  nom            String    @db.Text
  prenom         String    @db.Text
  espece         String    @db.Text
  age            Int
  date_naissance DateTime? @db.Date
  faceclaim      String    @db.Text
  avatar_url     String?   @db.Text
  metier         String?   @db.Text
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)

  player Player @relation(fields: [discord_id, guild_id], references: [discord_id, guild_id], onDelete: Cascade)

  @@unique([discord_id, guild_id])
  @@map("characters")
}

/// Race jouable, gérée par les admins via /races add|remove.
/// Globale (non scopée par guild). Soft-delete via is_active = false.
model Race {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nom        String   @unique @db.Text
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("races")
}

/// Correspondance image ↔ signification du deck Tarokka.
/// Images dans Supabase Storage bucket "tarroka" : tarokka deck_0001.jpg … 0040.jpg
model TarokkaSuit {
  id          String        @id @db.Text     // 'stars' | 'swords' | 'coins' | 'glyphs'
  name        String        @db.Text
  description String        @db.Text

  cards TarokkaCard[]

  @@map("tarokka_suits")
}

model TarokkaCard {
  image_num  Int    @id                      // 1–40
  suit_id    String @db.Text
  position   Int                             // 0 = Master, 1–9
  card_label String @db.Text                // "Master of Stars", "One of Stars"…
  card_name  String @db.Text                // "Wizard", "Transmuter"…
  represents String @db.Text

  suit TarokkaSuit @relation(fields: [suit_id], references: [id])

  @@map("tarokka_cards")
}

/// Log des souhaits d'anniversaire — une entrée par (personnage, année).
/// Évite les doublons si le bot redémarre ou si la commande est appelée plusieurs fois.
model BirthdayLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  character_id String    @db.Uuid
  year         Int
  wished_at    DateTime  @default(now()) @db.Timestamptz(6)

  character Character @relation(fields: [character_id], references: [id], onDelete: Cascade)

  @@unique([character_id, year])
  @@map("birthday_log")
}

/// Configuration JSON par serveur Discord.
/// config JSONB : { "admin_role_ids": ["<id>", ...], ... }
model GuildConfig {
  guild_id   String   @id @db.Text
  config     Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("guild_config")
}

/// Type de météo avec poids de probabilité (poids total = 100).
model WeatherType {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nom         String       @unique @db.Text
  description String       @db.Text
  emoji       String       @db.Text
  poids       Int
  created_at  DateTime     @default(now()) @db.Timestamptz(6)

  weatherLogs WeatherLog[]

  @@map("weather_types")
}

/// Météo du jour par guilde. Une seule entrée par (guild_id, date).
model WeatherLog {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guild_id   String      @db.Text
  date       DateTime    @db.Date
  weather_id String      @db.Uuid
  created_at DateTime    @default(now()) @db.Timestamptz(6)

  weatherType WeatherType @relation(fields: [weather_id], references: [id])

  @@unique([guild_id, date])
  @@map("weather_log")
}
